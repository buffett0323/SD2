\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces One denoising step under schema \texttt  {\{"count":int,\,"label":str\}}. \textbf  {LAVE} \citep  {zhang2026lookaheadthenverifyreliableconstraineddecoding} (left) samples $K$ random completions at each frontier token, accepting it only when $\geq \!1$ suffix is valid—stochastic and $K\!\times $ more expensive per token, hitting the 120\,s per-instance timeout on hard schemas. \textbf  {Dgrammar} (right) runs \texttt  {compute\_mask} on the incremental FSM state and unmasks an entire block under that mask in one forward pass, overlapped with the next mask computation; the result is deterministic.}}{5}{figure.caption.14}\protected@file@percent }
\newlabel{fig:denoise-compare}{{2}{5}{One denoising step under schema \texttt {\{"count":int,\,"label":str\}}. \textbf {LAVE} \citep {zhang2026lookaheadthenverifyreliableconstraineddecoding} (left) samples $K$ random completions at each frontier token, accepting it only when $\geq \!1$ suffix is valid—stochastic and $K\!\times $ more expensive per token, hitting the 120\,s per-instance timeout on hard schemas. \textbf {Dgrammar} (right) runs \texttt {compute\_mask} on the incremental FSM state and unmasks an entire block under that mask in one forward pass, overlapped with the next mask computation; the result is deterministic}{figure.caption.14}{}}
\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces \texttt  {jsb\_medium} results (seed 0, $T{=}128$ steps). Dgrammar and DPGrammar are evaluated on the same 511 instances (nine-shard protocol); DPGrammar adds \texttt  {dp\_fix\_prefix} on top. LAVE \citep  {zhang2026lookaheadthenverifyreliableconstraineddecoding} uses a nine-shard split covering 586 instances.}}{5}{table.caption.18}\protected@file@percent }
\newlabel{tab:main}{{1}{5}{\texttt {jsb\_medium} results (seed 0, $T{=}128$ steps). Dgrammar and DPGrammar are evaluated on the same 511 instances (nine-shard protocol); DPGrammar adds \texttt {dp\_fix\_prefix} on top. LAVE \citep {zhang2026lookaheadthenverifyreliableconstraineddecoding} uses a nine-shard split covering 586 instances}{table.caption.18}{}}
